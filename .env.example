# Configuracion del puente Conga 8090 <-> Home Assistant
# Copia este fichero como  .env  y rellena tus valores.
# El .env NO se debe subir a git (anadelo a .gitignore).

# --- MQTT (broker Mosquitto de Home Assistant) ---
MQTT_HOST=192.168.1.X
MQTT_PORT=1883
MQTT_USER=tu_usuario_mqtt
MQTT_PASS=tu_password_mqtt

# --- Robot (los de tu Conga; se sacan del login capturado) ---
# Si no los pones, usa los valores por defecto del script.
ROBOT_DID=123456
ROBOT_USERID=654321
ROBOT_SN=500400000000
ROBOT_MAC=12:34:56:78:9A:BC
FACTORY_ID=1003
PROJECT_TYPE=CECOTECCRL350-1001

# JWT del login. Tres opciones:
#   1) Pega aqui el AUTH capturado de tu robot (funciona seguro):
# AUTH_JWT=eyJ0eXAiOiJKV1Qi...
#   2) Dejalo VACIO (o comentado) -> el puente genera uno SINTÉTICO sin caducidad.
#   3) USE_SYNTHETIC_JWT=on -> fuerza el sintético aunque pongas AUTH_JWT arriba.
# El robot NO valida la firma del JWT, asi que el sintético suele funcionar y
# evita la caducidad del token capturado. Verifica con test_jwt_sintetico.py.
AUTH_JWT=
USE_SYNTHETIC_JWT=off

# --- Puerto de escucha del robot ---
LISTEN_PORT=9090

# --- Configuracion de limpieza por defecto (para limpiar por habitacion) ---
# Potencia: Off / Eco / Normal / Turbo
DEFAULT_FAN=Normal
# Agua: Off / Bajo / Medio / Alto
DEFAULT_WATER=Medio
# Vibracion mopa: Off / Estándar / Fuerte / Potente
DEFAULT_MOP=Estándar
# Doble pasada x2: on / off
DEFAULT_TWICE=off
